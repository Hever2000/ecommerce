# =============================================================================
# Ecommerce AWS â€” Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Application
NODE_ENV=development
PORT=3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecommerce?schema=public

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=your-mp-access-token
MERCADO_PAGO_WEBHOOK_SECRET=your-mp-webhook-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AWS S3 (Storage)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ecommerce-bucket-santiagocoronel
AWS_S3_BUCKET_NAME=ecommerce-bucket-santiagocoronel

# Resend (Email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# CORS
CORS_ORIGIN=http://localhost:3001

